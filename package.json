{
  "name": "@aman_asmuei/aflow",
  "version": "0.1.0",
  "description": "The portable workflow layer for AI companions — define multi-step AI workflows in a single file",
  "type": "module",
  "bin": {
    "aflow": "./bin/aflow.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "bin",
    "template"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "llm",
    "workflows",
    "orchestration",
    "cli",
    "acore"
  ],
  "author": "Aman Asmuei",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amanasmuei/aflow.git"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
